{
  "name": "ai-text-assistant",
  "version": "0.1.0",
  "description": "Desktop AI assistant for selected text summarization and translation",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev:electron": "wait-on tcp:5173 dist/main/index.js dist/preload/index.js && nodemon --watch dist/main --watch dist/preload --exec \"electron .\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "start": "electron ."
  },
  "build": {
    "appId": "com.mildempeach.ai-text-assistant",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "electron-log": "^5.3.0",
    "electron-store": "^10.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "concurrently": "^9.1.2",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
